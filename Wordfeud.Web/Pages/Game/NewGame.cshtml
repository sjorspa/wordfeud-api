@page "/game/new"
@model Wordfeud.Web.Pages.Game.NewGameModel
@{
    ViewData["Title"] = "Create New Game - Wordfeud";
}

<div class="max-w-lg mx-auto">
    <!-- Back Button -->
    <a href="/" class="inline-flex items-center text-gray-400 hover:text-white mb-6 transition-colors">
        <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Home
    </a>

    <!-- Create Game Card -->
    <div class="bg-gray-800 rounded-2xl shadow-2xl p-8">
        <h1 class="text-3xl font-bold text-center mb-2 text-tile-gold">&#10133; Create New Game</h1>
        <p class="text-center text-gray-400 mb-8">Enter your name to start a new game</p>

        @if (Model.ShowWaiting)
        {
            <!-- Waiting for opponent -->
            <div class="text-center">
                <div class="bg-gray-900 rounded-xl p-6 mb-6">
                    <p class="text-gray-400 mb-2">Your Game ID</p>
                    <div class="flex items-center justify-center gap-3">
                        <span id="game-id-display" class="text-2xl font-mono font-bold text-tile-gold">@Model.GameId</span>
                        <button onclick="copyGameId()" class="px-3 py-1.5 bg-gray-700 hover:bg-gray-600 rounded-lg text-sm transition-colors flex items-center gap-1.5">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                            </svg>
                            <span id="copy-text">Copy</span>
                        </button>
                    </div>
                </div>

                <div class="flex flex-col items-center gap-4">
                    <div class="flex items-center gap-3 text-green-400">
                        <div class="spinner"></div>
                        <span class="text-lg">Waiting for opponent to join...</span>
                    </div>
                    <p class="text-gray-500 text-sm">Share your game ID with a friend</p>
                    <a href="/game/@Model.GameId" class="px-6 py-3 bg-gradient-to-r from-green-600 to-green-700 hover:from-green-500 hover:to-green-600 rounded-xl font-semibold transition-all">
                        &#128187; Enter Game Board
                    </a>
                </div>
            </div>
        }
        else
        {
            <!-- Form -->
            <form method="post" class="space-y-6">
                <div>
                    <label asp-for="PlayerName" class="block text-sm font-medium text-gray-300 mb-2">Your Name</label>
                    <input asp-for="PlayerName" type="text" maxlength="50"
                           class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all"
                           placeholder="Enter your name..." required />
                    <span asp-validation-for="PlayerName" class="text-red-400 text-sm"></span>
                </div>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="bg-red-900/50 border border-red-700 rounded-xl p-4 text-red-200">
                        @Model.ErrorMessage
                    </div>
                }

                <button type="submit" id="create-btn"
                        class="w-full py-4 bg-gradient-to-r from-green-600 to-green-700 hover:from-green-500 hover:to-green-600 text-white text-lg font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed">
                    &#127919; Create Game
                </button>
            </form>
        }
    </div>
</div>

@section Scripts {
<script src="~/js/game-new.js"></script>
}
