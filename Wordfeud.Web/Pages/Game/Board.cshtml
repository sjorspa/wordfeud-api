@page "/game/{GameId}"
@using System.Linq
@model Wordfeud.Web.Pages.Game.BoardModel
@{
    ViewData["Title"] = $"Game {Model.GameId} - Wordfeud";
}

<div class="max-w-6xl mx-auto">
    <!-- Back Button -->
    <a href="/" class="inline-flex items-center text-gray-400 hover:text-white mb-4 transition-colors">
        <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Home
    </a>

    @if (Model.Game != null)
    {
        <!-- Hidden input for current player ID (set by server-side session) -->
        <input type="hidden" id="current-player-id" value="@Model.CurrentPlayerId" />
        
        <div class="flex flex-col lg:flex-row gap-6">
            <!-- Left Panel: Score & Info -->
            <div class="lg:w-64 order-2 lg:order-1">
                <!-- Score Panel -->
                <div class="bg-gray-800 rounded-2xl shadow-xl p-4 mb-4">
                    <h3 class="text-lg font-bold text-tile-gold mb-3">Scores</h3>
                    @foreach (var player in Model.Game.Players)
                    {
                        var isCurrentPlayer = player.Id == Model.Game.CurrentPlayerId;
                        var isYou = player.Id == Model.CurrentPlayerId;
                        <div class="flex items-center justify-between p-2 rounded-lg @(isCurrentPlayer ? "bg-gray-700" : "") @(isYou ? "ring-2 ring-tile-gold" : "") mb-2">
                            <div>
                                <span class="font-semibold @(isYou ? "text-tile-gold" : "text-white")">@player.Name</span>
                                @if (isYou)
                                {
                                    <span class="text-xs text-gray-400 ml-2">(You)</span>
                                }
                                @if (isCurrentPlayer)
                                {
                                    <span class="ml-2 text-xs text-green-400">&#9679;</span>
                                }
                            </div>
                            <span class="text-xl font-bold text-white">@player.Score</span>
                        </div>
                    }
                </div>

                <!-- Game Status -->
                <div class="bg-gray-800 rounded-2xl shadow-xl p-4 mb-4">
                    <h3 class="text-lg font-bold text-tile-gold mb-3">Game Info</h3>
                    <div class="space-y-2 text-sm">
                        <div class="flex justify-between">
                            <span class="text-gray-400">Status:</span>
                            <span class="font-semibold @(Model.Game.Status == "Active" ? "text-green-400" : "text-yellow-400")">@Model.Game.Status</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-400">Turn:</span>
                            <span class="font-semibold text-white">
                                @(Model.Game.CurrentPlayerId == Model.CurrentPlayerId ? "Your turn" : "Opponent's turn")
                            </span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-400">Move:</span>
                            <span class="font-mono text-white">#@(Model.Game.MoveNumber)</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-400">Bag:</span>
                            <span class="font-mono text-white">@Model.Game.BagCount</span>
                        </div>
                    </div>
                </div>

                <!-- Move History -->
                <div class="bg-gray-800 rounded-2xl shadow-xl p-4">
                    <h3 class="text-lg font-bold text-tile-gold mb-3">Move History</h3>
                    <div class="max-h-64 overflow-y-auto space-y-2">
                        @if (Model.MoveHistory != null && Model.MoveHistory.Count > 0)
                        {
                            @foreach (var move in Model.MoveHistory)
                            {
                                <div class="text-xs p-2 bg-gray-900 rounded">
                                    <span class="font-semibold text-tile-gold">@move.PlayerName</span>
                                    @if (!string.IsNullOrEmpty(move.Word))
                                    {
                                        <span class="text-gray-400 ml-1">placed "@move.Word"</span>
                                    }
                                    else
                                    {
                                        <span class="text-gray-400 ml-1">(@move.ActionType)</span>
                                    }
                                    <span class="text-green-400 ml-1">+@move.Score pts</span>
                                    <span class="text-gray-500 ml-1">#@move.MoveNumber</span>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-gray-500 text-sm">No moves yet</p>
                        }
                    </div>
                </div>
            </div>

            <!-- Center: Game Board -->
            <div class="flex-1 order-1 lg:order-2 flex flex-col items-center">
                <!-- Turn Indicator -->
                <div class="mb-4 px-6 py-2 rounded-full @(Model.Game.CurrentPlayerId == Model.CurrentPlayerId ? "bg-green-600" : "bg-yellow-600")">
                    <span class="font-semibold">@(Model.Game.CurrentPlayerId == Model.CurrentPlayerId ? "Your Turn" : "Opponent's Turn")</span>
                </div>

                <!-- Board Container with coordinate labels -->
                <div class="relative">
                    <!-- Column labels (A-O) -->
                    <div class="flex justify-center mb-1">
                        <div class="w-6 sm:w-8"></div>
                        @for (var col = 0; col < 15; col++)
                        {
                            <span class="flex-1 text-center text-[0.55rem] sm:text-[0.65rem] font-mono text-gray-400 select-none">@((char)('A' + col))</span>
                        }
                    </div>

                    <div class="flex">
                        <!-- Row labels (1-15) -->
                        <div class="flex flex-col justify-center w-6 sm:w-8">
                            @for (var row = 0; row < 15; row++)
                            {
                                <span class="flex-1 flex items-center justify-center text-[0.55rem] sm:text-[0.65rem] font-mono text-gray-400 select-none">@(row + 1)</span>
                            }
                        </div>

                        <!-- Board -->
                        <div class="bg-board-dark p-1 sm:p-2 rounded-xl shadow-2xl" style="background: linear-gradient(145deg, #339966, #206955);">
                            <div id="board-container" class="grid grid-cols-15 gap-1 border-2 border-board-border"
                                 style="width: min(90vw, calc(15 * 3rem + 14 * 0.25rem)); height: min(90vw, calc(15 * 3rem + 14 * 0.25rem));">
                                @for (var row = 0; row < 15; row++)
                                {
                                    @for (var col = 0; col < 15; col++)
                                    {
                                        var bonus = GetBonusType(row, col);
                                        var cellClass = "relative flex items-center justify-center text-[0.45rem] sm:text-[0.6rem] font-bold uppercase select-none";
                                        var bonusClass = "";
                                        var icon = "";

                                        switch (bonus)
                                        {
                                            case "TW":
                                                bonusClass = "bonus-tws";
                                                icon = "TW";
                                                break;
                                            case "DW":
                                                bonusClass = "bonus-dws";
                                                icon = "DW";
                                                break;
                                            case "DL":
                                                bonusClass = "bonus-dls";
                                                icon = "DL";
                                                break;
                                            case "TL":
                                                bonusClass = "bonus-tls";
                                                icon = "TL";
                                                break;
                                            case "STAR":
                                                bonusClass = "bonus-star";
                                                icon = "★";
                                                break;
                                        }

                                        <div class="@(cellClass) @(bonusClass) board-cell"
                                             style="background: @(string.IsNullOrEmpty(bonus) ? "#339966" : "inherit");"
                                             data-row="@row" data-col="@col"
                                             ondragover="event.preventDefault(); this.classList.add('drop-hover')"
                                             ondragleave="this.classList.remove('drop-hover')"
                                             ondrop="handleDrop(event, @row, @col)"
                                             ondragenter="handleDragEnter(@row, @col)"
                                             ondragleave="handleDragLeave()">
                                            @if (!string.IsNullOrEmpty(icon))
                                            {
                                                <span class="drop-shadow-sm leading-none">@icon</span>
                                            }
                                            @if (!string.IsNullOrEmpty(bonus))
                                            {
                                                var arrows = GetBonusArrows(row, col, bonus);
                                                foreach (var arrow in arrows)
                                                {
                                                    <span class="bonus-arrow @arrow"></span>
                                                }
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Placed Tiles Preview -->
                <div id="placed-tiles-preview" class="mt-4 min-h-[3.5rem] flex items-center gap-2 p-3 bg-gray-800 rounded-xl w-full max-w-lg" role="status" aria-live="polite">
                    <span class="text-gray-500 text-sm">Drag tiles from your rack onto the board</span>
                </div>

                <!-- Board Zoom Controls -->
                <div class="flex items-center gap-2 mt-3 justify-center" aria-label="Board zoom controls">
                    <button onclick="zoomBoard(-1)" class="p-1.5 bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors text-sm" aria-label="Zoom out board">
                        &#8722;
                    </button>
                    <span class="text-xs text-gray-400 min-w-[3rem] text-center" id="zoom-level">100%</span>
                    <button onclick="zoomBoard(1)" class="p-1.5 bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors text-sm" aria-label="Zoom in board">
                        &#43;
                    </button>
                    <button onclick="zoomBoard(0)" class="p-1.5 bg-gray-700 hover:bg-gray-600 rounded-lg transition-colors text-xs ml-1" id="reset-zoom-btn" aria-label="Reset zoom" style="min-width: 2rem;">
                        R
                    </button>
                </div>

                <!-- Settings Button Container -->
                <div id="settings-container" class="flex items-center gap-2 mt-2 justify-center"></div>

                <!-- Action Buttons -->
                <div class="flex flex-wrap gap-2 mt-4 w-full max-w-lg justify-center">
                    <button onclick="placeWord()" id="place-btn" class="px-5 py-2.5 bg-green-600 hover:bg-green-500 disabled:bg-gray-600 disabled:cursor-not-allowed text-white font-semibold rounded-xl transition-all text-sm" aria-label="Place word on board">
                        &#10003; Place Word
                    </button>
                    <button onclick="recallTiles()" class="px-5 py-2.5 bg-yellow-600 hover:bg-yellow-500 text-white font-semibold rounded-xl transition-all text-sm" aria-label="Recall all tiles to rack">
                        &#8634; Recall
                    </button>
                    <button onclick="undoLastMove()" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-xl transition-all text-sm" aria-label="Undo last move" id="undo-btn" style="display:none;">
                        &#8630; Undo
                    </button>
                    <button onclick="passTurn()" class="px-5 py-2.5 bg-gray-600 hover:bg-gray-500 text-white font-semibold rounded-xl transition-all text-sm" aria-label="Pass turn to opponent">
                        &#9203; Pass
                    </button>
                    <button onclick="showSwapModal()" class="px-5 py-2.5 bg-purple-600 hover:bg-purple-500 text-white font-semibold rounded-xl transition-all text-sm" aria-label="Swap tiles with bag">
                        &#8645; Swap
                    </button>
                    <button onclick="leaveGame()" class="px-5 py-2.5 bg-red-700 hover:bg-red-600 text-white font-semibold rounded-xl transition-all text-sm" aria-label="Leave this game">
                        &#128683; Leave
                    </button>
                </div>

                <!-- Tile Rack (populated by JavaScript) -->
                <div class="mt-6" style="background: linear-gradient(145deg, #c9a86c, #8b6914); padding: 0.75rem 1rem; border-radius: 1rem; box-shadow: 0 3px 10px rgba(0,0,0,0.3);">
                    <div id="tile-rack" class="flex gap-1 sm:gap-2 justify-center">
                        <div class="tile" data-tile-id="loading" data-points="0">
                            <span class="animate-pulse">...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-20">
            <div class="spinner mx-auto mb-4"></div>
            <p class="text-gray-400">Loading game...</p>
        </div>
    }
</div>

<!-- Blank Tile Letter Picker Modal -->
<div id="blank-modal" class="fixed inset-0 modal-overlay z-50 hidden flex items-center justify-center">
    <div class="bg-gray-800 rounded-2xl shadow-2xl p-6 max-w-md w-full mx-4">
        <h3 class="text-xl font-bold text-tile-gold mb-4">Choose a letter for blank tile</h3>
        <div class="grid grid-cols-7 gap-2 mb-4">
            @foreach (var letter in "ABCDEFGHIJKLMNOPQRSTUVWXYZ".Select((c, i) => new { Letter = c.ToString(), Index = i }))
            {
                <button onclick="selectBlankLetter('@letter.Letter')" class="tile text-lg hover:scale-110 transition-transform">
                    @letter.Letter
                </button>
            }
        </div>
        <button onclick="closeBlankModal()" class="w-full py-2 bg-gray-700 hover:bg-gray-600 rounded-xl text-gray-300">Cancel</button>
    </div>
</div>

<!-- Swap Tiles Modal -->
<div id="swap-modal" class="fixed inset-0 modal-overlay z-50 hidden flex items-center justify-center">
    <div class="bg-gray-800 rounded-2xl shadow-2xl p-6 max-w-md w-full mx-4">
        <h3 class="text-xl font-bold text-tile-gold mb-4">Swap Tiles</h3>
        <p class="text-gray-400 text-sm mb-4">Select tiles to swap (costs a turn):</p>
        <div id="swap-tile-list" class="space-y-2 mb-4 max-h-64 overflow-y-auto">
            <!-- Populated by JS -->
        </div>
        <div class="flex gap-1">
            <button onclick="closeSwapModal()" class="flex-1 py-2 bg-gray-700 hover:bg-gray-600 rounded-xl text-gray-300">Cancel</button>
            <button onclick="confirmSwap()" class="flex-1 py-2 bg-purple-600 hover:bg-purple-500 rounded-xl text-white font-semibold">Swap</button>
        </div>
    </div>
</div>

<!-- Settings Modal -->
<div id="settings-modal" class="fixed inset-0 modal-overlay z-50 hidden flex items-center justify-center">
    <div class="bg-gray-800 rounded-2xl shadow-2xl p-6 max-w-md w-full mx-4">
        <h3 class="text-xl font-bold text-tile-gold mb-4">Settings</h3>
        <div class="space-y-4 mb-6">
            <!-- Dark/Light Mode Toggle -->
            <div class="flex items-center justify-between p-3 bg-gray-900 rounded-lg">
                <div>
                    <p class="font-semibold text-white">Dark Mode</p>
                    <p class="text-xs text-gray-400">Toggle dark/light theme</p>
                </div>
                <button onclick="toggleTheme()" class="w-12 h-6 rounded-full bg-gray-600 relative transition-colors" id="theme-toggle" aria-label="Toggle dark mode">
                    <div class="w-5 h-5 bg-white rounded-full absolute top-0.5 left-0.5 transition-transform" id="theme-toggle-dot"></div>
                </button>
            </div>

            <!-- Colorblind Mode Toggle -->
            <div class="flex items-center justify-between p-3 bg-gray-900 rounded-lg">
                <div>
                    <p class="font-semibold text-white">Colorblind Mode</p>
                    <p class="text-xs text-gray-400">Enhanced bonus square patterns</p>
                </div>
                <button onclick="toggleColorblindMode()" class="w-12 h-6 rounded-full bg-gray-600 relative transition-colors" id="colorblind-toggle" aria-label="Toggle colorblind mode">
                    <div class="w-5 h-5 bg-white rounded-full absolute top-0.5 left-0.5 transition-transform" id="colorblind-toggle-dot"></div>
                </button>
            </div>

            <!-- Keyboard Shortcuts Help -->
            <div class="p-3 bg-gray-900 rounded-lg">
                <p class="font-semibold text-white mb-2">Keyboard Shortcuts</p>
                <div class="text-xs text-gray-400 space-y-1">
                    <div class="flex justify-between"><span>Place Word</span><kbd class="px-1.5 py-0.5 bg-gray-700 rounded">Space</kbd></div>
                    <div class="flex justify-between"><span>Recall Tiles</span><kbd class="px-1.5 py-0.5 bg-gray-700 rounded">Ctrl+Z</kbd></div>
                    <div class="flex justify-between"><span>Undo Move</span><kbd class="px-1.5 py-0.5 bg-gray-700 rounded">Ctrl+Shift+Z</kbd></div>
                    <div class="flex justify-between"><span>Zoom In/Out</span><kbd class="px-1.5 py-0.5 bg-gray-700 rounded">Ctrl+=/-</kbd></div>
                    <div class="flex justify-between"><span>Pass Turn</span><kbd class="px-1.5 py-0.5 bg-gray-700 rounded">P</kbd></div>
                    <div class="flex justify-between"><span>Swap Tiles</span><kbd class="px-1.5 py-0.5 bg-gray-700 rounded">S</kbd></div>
                    <div class="flex justify-between"><span>Toggle Theme</span><kbd class="px-1.5 py-0.5 bg-gray-700 rounded">T</kbd></div>
                    <div class="flex justify-between"><span>Colorblind Mode</span><kbd class="px-1.5 py-0.5 bg-gray-700 rounded">C</kbd></div>
                    <div class="flex justify-between"><span>Leave Game</span><kbd class="px-1.5 py-0.5 bg-gray-700 rounded">L</kbd></div>
                    <div class="flex justify-between"><span>Escape/Cancel</span><kbd class="px-1.5 py-0.5 bg-gray-700 rounded">Esc</kbd></div>
                </div>
            </div>
        </div>
        <button onclick="closeSettingsModal()" class="w-full py-2 bg-gray-700 hover:bg-gray-600 rounded-xl text-gray-300">Close</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/game-board.js"></script>
}

@* Helper to get bonus type for a cell *@
@functions {
    public static string GetBonusType(int row, int col)
    {
        // Double Word - pink
        var dw = new (int, int)[] { (1,1),(2,2),(3,3),(4,4),(1,13),(2,12),(3,11),(4,10),(10,4),(11,3),(12,2),(13,1),(10,10),(11,11),(12,12),(13,13) };
        // Triple Word - red
        var tw = new (int, int)[] { (0,0),(0,7),(0,14),(7,0),(7,14),(14,0),(14,7),(14,14) };
        // Triple Letter - dark blue
        var tl = new (int, int)[] { (1,5),(1,9),(5,1),(5,5),(5,9),(5,13),(9,1),(9,5),(9,9),(9,13),(13,5),(13,9) };
        // Double Letter - light blue
        var dl = new (int, int)[] { (0,3),(0,11),(2,6),(2,8),(3,0),(3,7),(3,14),(6,2),(6,6),(6,8),(6,12),(7,3),(7,11),(8,2),(8,6),(8,8),(8,12),(11,0),(11,7),(11,14),(12,6),(12,8),(14,3),(14,11) };

        if (row == 7 && col == 7) return "STAR";
        if (tl.Any(x => x.Item1 == row && x.Item2 == col)) return "TL";
        if (dl.Any(x => x.Item1 == row && x.Item2 == col)) return "DL";
        if (dw.Any(x => x.Item1 == row && x.Item2 == col)) return "DW";
        if (tw.Any(x => x.Item1 == row && x.Item2 == col)) return "TW";
        return "";
    }

    public static string[] GetBonusArrows(int row, int col, string bonusType)
    {
        if (string.IsNullOrEmpty(bonusType)) return Array.Empty<string>();

        var arrows = new List<string>();

        // Check each direction for adjacent squares of the same bonus type
        // Up
        if (row > 0 && GetBonusType(row - 1, col) == bonusType) arrows.Add("arrow-up");
        // Down
        if (row < 14 && GetBonusType(row + 1, col) == bonusType) arrows.Add("arrow-down");
        // Left
        if (col > 0 && GetBonusType(row, col - 1) == bonusType) arrows.Add("arrow-left");
        // Right
        if (col < 14 && GetBonusType(row, col + 1) == bonusType) arrows.Add("arrow-right");

        return arrows.ToArray();
    }
}
