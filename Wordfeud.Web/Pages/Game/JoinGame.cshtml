@page "/game/join"
@model Wordfeud.Web.Pages.Game.JoinGameModel
@{
    ViewData["Title"] = "Join Game - Wordfeud";
}

<div class="max-w-lg mx-auto">
    <!-- Back Button -->
    <a href="/" class="inline-flex items-center text-gray-400 hover:text-white mb-6 transition-colors">
        <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Home
    </a>

    <!-- Join Game Card -->
    <div class="bg-gray-800 rounded-2xl shadow-2xl p-8">
        <h1 class="text-3xl font-bold text-center mb-2 text-tile-gold">&#9650; Join a Game</h1>
        <p class="text-center text-gray-400 mb-8">Enter the game ID and your name</p>

        <form method="post" class="space-y-6">
            @Html.AntiForgeryToken()
            <div>
                <label asp-for="GameId" class="block text-sm font-medium text-gray-300 mb-2">Game ID</label>
                <input asp-for="GameId" type="text"
                       class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white font-mono placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all uppercase"
                       placeholder="Enter game ID..." required />
                <span asp-validation-for="GameId" class="text-red-400 text-sm"></span>
            </div>

            <div>
                <label asp-for="PlayerName" class="block text-sm font-medium text-gray-300 mb-2">Your Name</label>
                <input asp-for="PlayerName" type="text" maxlength="50"
                       class="w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                       placeholder="Enter your name..." required />
                <span asp-validation-for="PlayerName" class="text-red-400 text-sm"></span>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="bg-red-900/50 border border-red-700 rounded-xl p-4 text-red-200">
                    @Model.ErrorMessage
                </div>
            }

            <button type="submit" id="join-btn"
                    class="w-full py-4 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-500 hover:to-blue-600 text-white text-lg font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed">
                &#128274; Join Game
            </button>
        </form>
    </div>
</div>

@section Scripts {
<script src="~/js/game-join.js"></script>
}
