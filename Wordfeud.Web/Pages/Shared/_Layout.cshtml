<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Wordfeud</title>
    <link rel="icon" href="~/favicon.ico" />
    <link href='https://fonts.googleapis.com/css?family=Asap' rel='stylesheet' type='text/css'>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        board: '#339966',
                        'board-dark': '#206955',
                        'board-light': '#44aa77',
                        'board-border': '#1a5c3a',
                        'tile-cream': '#fae1a6',
                        'tile-dark': '#d8bd72',
                        'tile-gold': '#f0c040',
                        'wood': '#c9a86c',
                        'wood-dark': '#8b6914',
                    },
                    gridTemplateColumns: {
                        '15': 'repeat(15, minmax(0, 1fr))'
                    }
                }
            }
        }
    </script>
    <style>
        /* Board bonus square colors */
        .bonus-tws { background-color: #d72421; color: #f8bdb4; }
        .bonus-dws { background-color: #b86e74; color: white; }
        .bonus-dls { background-color: #5d94c5; color: white; }
        .bonus-tls { background-color: #4695ca; color: #c3f5f7; }
        .bonus-star { background-color: #d72421; color: #f8bdb4; }

        /* Colorblind mode bonus square colors - uses patterns in addition to colors */
        .colorblind-mode .bonus-tws { background-color: #d72421; color: #f8bdb4; background-image: repeating-linear-gradient(45deg, transparent, transparent 3px, rgba(255,255,255,0.3) 3px, rgba(255,255,255,0.3) 6px); }
        .colorblind-mode .bonus-dws { background-color: #b86e74; color: white; background-image: repeating-linear-gradient(45deg, transparent, transparent 3px, rgba(255,255,255,0.3) 3px, rgba(255,255,255,0.3) 6px); }
        .colorblind-mode .bonus-dls { background-color: #5d94c5; color: white; background-image: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(255,255,255,0.3) 3px, rgba(255,255,255,0.3) 6px); }
        .colorblind-mode .bonus-tls { background-color: #4695ca; color: #c3f5f7; background-image: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(255,255,255,0.3) 3px, rgba(255,255,255,0.3) 6px); }
        .colorblind-mode .bonus-star { background-color: #d72421; color: #f8bdb4; background-image: repeating-linear-gradient(45deg, transparent, transparent 3px, rgba(255,255,255,0.3) 3px, rgba(255,255,255,0.3) 6px); }

        /* Tile styles */
        .tile {
            width: 2.5rem;
            height: 2.5rem;
            background: linear-gradient(145deg, #d8bd72, #fae1a6);
            border: 1.5px solid #f8e6b1;
            border-top-width: 1px;
            border-right-width: 4px;
            border-bottom-width: 4px;
            border-left-width: 1px;
            border-top-color: #f8e6b1;
            border-right-color: #f8e6b1;
            border-bottom-color: #cab06b;
            border-left-color: #f8e6b1;
            border-radius: 0.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-family: 'Asap', serif;
            color: #272832;
            text-shadow: 1px 1px 0px #fff5d7;
            cursor: grab;
            user-select: none;
            -webkit-user-select: none;
            -moz-user-select: -moz-none;
            position: relative;
            box-shadow: 0px 3px 5px #000;
            transition: transform 0.15s ease, box-shadow 0.15s ease;
        }
        .tile:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.3);
        }
        .tile:active { cursor: grabbing; }
        .tile.selected {
            background: linear-gradient(145deg, #f0c040, #e0b030);
            border-color: #d72421;
            transform: translateY(-4px);
            box-shadow: 0 6px 12px rgba(0,0,0,0.3);
        }
        .tile .points {
            position: absolute;
            bottom: 1px;
            right: 3px;
            font-size: 0.55rem;
            color: #272832;
            text-shadow: 1px 1px 0px #fff5d7;
            line-height: 1;
        }
        .tile.blank-tile {
            background: linear-gradient(145deg, #d8bd72, #fae1a6);
        }

        /* Placed tile - fixed size */
        .placed-tile {
            width: 2.5rem;
            height: 2.5rem;
            background: linear-gradient(145deg, #d8bd72, #fae1a6);
            border: 1.5px solid #f8e6b1;
            border-top-width: 1px;
            border-right-width: 4px;
            border-bottom-width: 4px;
            border-left-width: 1px;
            border-top-color: #f8e6b1;
            border-right-color: #f8e6b1;
            border-bottom-color: #cab06b;
            border-left-color: #f8e6b1;
            border-radius: 0.35rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-family: 'Asap', serif;
            color: #272832;
            text-shadow: 1px 1px 0px #fff5d7;
            cursor: pointer;
            position: relative;
            box-shadow: 0px 3px 5px #000;
            animation: tileFadeIn 0.2s ease;
        }
        .placed-tile .points {
            font-size: 0.55rem;
            position: absolute;
            bottom: 1px;
            right: 2px;
            color: #272832;
            text-shadow: 1px 1px 0px #fff5d7;
            line-height: 1;
        }
        .placed-tile span {
            font-size: 0.8rem;
        }

        /* Last move highlight */
        .placed-tile.last-move {
            border-color: #f0c040;
            box-shadow: 0 0 8px rgba(240, 192, 64, 0.6), 0 2px 4px rgba(0,0,0,0.2);
            animation: lastMovePulse 2s ease-in-out infinite;
        }
        @@keyframes lastMovePulse {
            0%, 100% { box-shadow: 0 0 8px rgba(240, 192, 64, 0.4), 0 2px 4px rgba(0,0,0,0.2); }
            50% { box-shadow: 0 0 14px rgba(240, 192, 64, 0.7), 0 2px 6px rgba(0,0,0,0.3); }
        }

        /* Scoring preview tooltip */
        .scoring-preview {
            position: absolute;
            top: -50px;
            left: 50%;
            transform: translateX(-50%);
            background: #1f2937;
            border: 1px solid #f0c040;
            border-radius: 0.5rem;
            padding: 0.25rem 0.5rem;
            font-size: 0.65rem;
            color: #f0c040;
            white-space: nowrap;
            z-index: 10;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.15s ease;
        }
        .scoring-preview.visible {
            opacity: 1;
        }
        .scoring-preview::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 50%;
            transform: translateX(-50%);
            border-left: 5px solid transparent;
            border-right: 5px solid transparent;
            border-top: 5px solid #f0c040;
        }
        .placed-tile .remove-btn {
            position: absolute;
            top: -8px;
            right: -8px;
            width: 16px;
            height: 16px;
            background: #e94560;
            color: white;
            border: none;
            border-radius: 50%;
            font-size: 0.55rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            line-height: 1;
            opacity: 0;
            transition: opacity 0.15s ease;
        }
        .placed-tile:hover .remove-btn { opacity: 1; }

        @@keyframes tileFadeIn {
            from { opacity: 0; transform: scale(0.8); }
            to { opacity: 1; transform: scale(1); }
        }

        /* Board cell hover */
        .board-cell:hover { filter: brightness(1.1); }
        .board-cell.drop-hover { box-shadow: inset 0 0 0 3px #f0c040; }
        .board-cell.drop-invalid { box-shadow: inset 0 0 0 3px #e94560; }

        /* Toast animation */
        .toast-enter { animation: toastIn 0.3s ease forwards; }
        .toast-exit { animation: toastOut 0.3s ease forwards; }
        @@keyframes toastIn {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @@keyframes toastOut {
            from { opacity: 1; transform: translateY(0); }
            to { opacity: 0; transform: translateY(-20px); }
        }

        /* Modal */
        .modal-overlay {
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(4px);
        }

        /* Loading spinner */
        .spinner {
            border: 3px solid rgba(255,255,255,0.2);
            border-top-color: white;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            animation: spin 0.8s linear infinite;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }

        /* Responsive board - tiles drive the size */
        .board-cell-size {
            width: 2.5rem;
            height: 2.5rem;
        }

        /* Light mode styles */
        body.light {
            background-color: #f3f4f6;
            color: #111827;
        }
        body.light .bg-gray-800 { background-color: #ffffff; }
        body.light .bg-gray-900 { background-color: #f9fafb; }
        body.light .text-gray-100 { color: #1f2937; }
        body.light .text-gray-400 { color: #6b7280; }
        body.light .text-gray-500 { color: #9ca3af; }
        body.light .border-gray-700 { border-color: #e5e7eb; }
        body.light .hover\:bg-gray-600:hover { background-color: #f3f4f6; }
        body.light .hover\:bg-gray-500:hover { background-color: #e5e7eb; }

        /* Reduced motion support */
        @@media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }

        /* Responsive improvements */
        @@media (max-width: 640px) {
            .board-container-responsive {
                max-width: 100vw;
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
            }
            .tile-rack-responsive {
                max-width: 100vw;
                overflow-x: auto;
                padding-bottom: 0.5rem;
            }
            .action-buttons-responsive {
                flex-wrap: wrap;
                gap: 0.375rem;
            }
            .action-buttons-responsive button {
                flex: 1 1 auto;
                min-width: 3rem;
                padding: 0.375rem 0.5rem;
                font-size: 0.7rem;
            }
        }

        /* Print styles */
        @@media print {
            .no-print { display: none !important; }
            .board-cell-size { padding-top: 50px !important; }
        }

        /* High contrast mode */
        @@media (prefers-contrast: high) {
            .board-cell { border-width: 2px; }
            .tile { border-width: 2px; }
            .placed-tile { border-width: 2px; }
        }

        /* Focus visible styles for keyboard navigation */
        *:focus-visible {
            outline: 2px solid #f0c040;
            outline-offset: 2px;
        }

        /* Skip to main content link */
        .skip-link {
            position: absolute;
            top: -40px;
            left: 6px;
            background: #f0c040;
            color: #1f2937;
            padding: 8px;
            text-decoration: none;
            z-index: 100;
        }
        .skip-link:focus {
            top: 6px;
        }

        /* Screen reader only */
        .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border-width: 0;
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body class="bg-gray-900 text-gray-100 dark-mode min-h-screen">
    <!-- Toast Container -->
    <div id="toast-container" class="fixed top-4 right-4 z-50 flex flex-col gap-2 max-w-sm"></div>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-6">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="text-center py-6 text-gray-500 text-sm">
        <p>Wordfeud Clone &mdash; Built with ASP.NET Core &amp; TailwindCSS</p>
    </footer>

    <script src="~/js/app.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
