@page
@using Wordfeud.Web.Pages
@using System.Text.Json
@model IndexModel
@{
    ViewData["Title"] = "Wordfeud";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wordfeud</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #1a1a2e;
            color: #eee;
            min-height: 100vh;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        h1 {
            text-align: center;
            margin-bottom: 20px;
            color: #f0c040;
            font-size: 2.5rem;
        }

        /* Game creation / joining */
        .setup-panel {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
            margin: 40px auto;
            padding: 30px;
            background: #16213e;
            border-radius: 12px;
            max-width: 400px;
        }

        .setup-panel input {
            padding: 12px 16px;
            font-size: 1rem;
            border: 2px solid #0f3460;
            border-radius: 8px;
            background: #1a1a2e;
            color: #eee;
            width: 100%;
        }

        .setup-panel button {
            padding: 12px 30px;
            font-size: 1rem;
            background: #e94560;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
        }

        .setup-panel button:hover {
            background: #c73e54;
        }

        /* Layout */
        .game-layout {
            display: flex;
            gap: 20px;
            align-items: flex-start;
            justify-content: center;
            flex-wrap: wrap;
        }

        .player-panel {
            background: #16213e;
            border-radius: 12px;
            padding: 15px;
            min-width: 200px;
            max-width: 250px;
        }

        .player-panel.active {
            border: 3px solid #f0c040;
        }

        .player-panel h3 {
            margin-bottom: 10px;
            color: #f0c040;
        }

        .player-panel .score {
            font-size: 1.5rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        /* Rack */
        .rack {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            margin-bottom: 10px;
            min-height: 60px;
            padding: 10px;
            background: #0f3460;
            border-radius: 8px;
        }

        .rack-tile {
            width: 45px;
            height: 45px;
            background: #f5e6c4;
            color: #333;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            font-weight: bold;
            border-radius: 6px;
            border: 2px solid #c9a86c;
            cursor: grab;
            user-select: none;
            position: relative;
        }

        .rack-tile:active {
            cursor: grabbing;
        }

        .rack-tile:hover {
            border-color: #f0c040;
            transform: translateY(-2px);
        }

        .rack-tile.selected {
            background: #f0c040;
            border-color: #e94560;
            transform: translateY(-4px);
        }

        .rack-tile .points {
            position: absolute;
            bottom: 2px;
            right: 3px;
            font-size: 0.6rem;
            color: #666;
        }

        .rack-tile.blank-tile {
            background: #ddd;
        }

        /* Board */
        .board-container {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .board {
            display: grid;
            grid-template-columns: repeat(15, 36px);
            grid-template-rows: repeat(15, 36px);
            gap: 2px;
            background: #0f3460;
            padding: 4px;
            border-radius: 8px;
        }

        .board-cell {
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            font-weight: bold;
            border-radius: 4px;
            background: #e8dcc8;
            position: relative;
            transition: background-color 0.15s ease, box-shadow 0.15s ease;
        }

        .board-cell.drop-hover {
            box-shadow: inset 0 0 0 3px #f0c040;
            background-color: #fff8dc;
        }

        .board-cell.drop-invalid {
            box-shadow: inset 0 0 0 3px #e94560;
            background-color: #ffe0e0;
        }

        .board-cell.tws {
            background: #e94560;
            color: white;
        }

        .board-cell.dws {
            background: #f09060;
            color: white;
        }

        .board-cell.tls {
            background: #6090e0;
            color: white;
        }

        .board-cell.dls {
            background: #90c0f0;
            color: white;
        }

        .board-cell.center {
            background: #e94560;
            color: white;
            font-size: 0.6rem;
        }

        .board-cell .tile-on-board {
            width: 30px;
            height: 30px;
            background: #f5e6c4;
            color: #333;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            font-weight: bold;
            border-radius: 4px;
            border: 1px solid #c9a86c;
        }

        .board-cell .tile-on-board .points {
            position: absolute;
            bottom: 1px;
            right: 2px;
            font-size: 0.5rem;
            color: #666;
        }

        /* Placed tiles preview */
        .placed-tiles {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            justify-content: center;
            margin: 10px 0;
            min-height: 50px;
            padding: 8px;
            background: #1a1a2e;
            border-radius: 8px;
            border: 1px dashed #0f3460;
        }

        .placed-tile {
            width: 40px;
            height: 40px;
            background: #f0c040;
            color: #333;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            font-weight: bold;
            border-radius: 6px;
            border: 2px solid #e94560;
            cursor: pointer;
            position: relative;
            animation: fadeIn 0.2s ease;
        }

        .placed-tile:hover {
            transform: scale(1.1);
        }

        .placed-tile .remove-btn {
            position: absolute;
            top: -6px;
            right: -6px;
            width: 16px;
            height: 16px;
            background: #e94560;
            color: white;
            border: none;
            border-radius: 50%;
            font-size: 0.6rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            line-height: 1;
        }

        .placed-tile .pos-info {
            position: absolute;
            bottom: -1px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 0.45rem;
            color: #fff;
            background: #0f3460;
            padding: 0 2px;
            border-radius: 2px;
            white-space: nowrap;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: scale(0.8); }
            to { opacity: 1; transform: scale(1); }
        }

        /* Action bar */
        .action-bar {
            margin-top: 20px;
            padding: 15px;
            background: #16213e;
            border-radius: 12px;
            text-align: center;
        }

        .action-bar h4 {
            margin-bottom: 10px;
            color: #f0c040;
        }

        .action-bar form {
            display: inline-flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
        }

        .action-bar label {
            font-size: 0.9rem;
        }

        .action-bar input[type="number"] {
            width: 50px;
            padding: 6px;
            border: 2px solid #0f3460;
            border-radius: 6px;
            background: #1a1a2e;
            color: #eee;
            text-align: center;
        }

        .action-bar select {
            padding: 8px 12px;
            border: 2px solid #0f3460;
            border-radius: 6px;
            background: #1a1a2e;
            color: #eee;
        }

        .action-bar button {
            padding: 10px 20px;
            font-size: 0.95rem;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
        }

        .btn-place {
            background: #28a745;
            color: white;
        }

        .btn-place:hover {
            background: #218838;
        }

        .btn-swap {
            background: #ffc107;
            color: #333;
        }

        .btn-swap:hover {
            background: #e0a800;
        }

        .btn-pass {
            background: #6c757d;
            color: white;
        }

        .btn-pass:hover {
            background: #5a6268;
        }

        .btn-refresh {
            background: #0f3460;
            color: white;
        }

        .btn-refresh:hover {
            background: #1a4a80;
        }

        /* Status */
        .status-bar {
            margin-top: 15px;
            padding: 10px;
            background: #16213e;
            border-radius: 8px;
            text-align: center;
        }

        .status-bar .game-id {
            font-family: monospace;
            color: #f0c040;
        }

        /* Error messages */
        .error {
            color: #e94560;
            padding: 10px;
            background: rgba(233, 69, 96, 0.1);
            border-radius: 8px;
            margin-top: 10px;
        }

        /* Info */
        .info {
            margin-top: 10px;
            font-size: 0.85rem;
            color: #aaa;
        }

        /* Blank assignment modal */
        .blank-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            align-items: center;
            justify-content: center;
            z-index: 100;
        }

        .blank-modal.show {
            display: flex;
        }

        .blank-modal-content {
            background: #16213e;
            padding: 20px;
            border-radius: 12px;
            text-align: center;
        }

        .blank-modal-content input {
            width: 60px;
            padding: 10px;
            font-size: 1.5rem;
            text-align: center;
            border: 2px solid #0f3460;
            border-radius: 8px;
            background: #1a1a2e;
            color: #eee;
            text-transform: uppercase;
        }

        .blank-modal-content button {
            margin-top: 10px;
            padding: 8px 20px;
            background: #28a745;
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
        }

        /* Legend */
        .legend {
            margin-top: 15px;
            display: flex;
            gap: 15px;
            justify-content: center;
            flex-wrap: wrap;
            font-size: 0.8rem;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .legend-box {
            width: 18px;
            height: 18px;
            border-radius: 4px;
        }

        .legend-box.tws { background: #e94560; }
        .legend-box.dws { background: #f09060; }
        .legend-box.tls { background: #6090e0; }
        .legend-box.dls { background: #90c0f0; }

        /* Setup options */
        .setup-options {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            gap: 20px;
            align-items: start;
            margin: 20px 0;
        }

        .setup-option {
            background: #16213e;
            padding: 20px;
            border-radius: 12px;
            border: 2px solid #0f3460;
        }

        .setup-option h3 {
            color: #f0c040;
            margin-bottom: 15px;
            font-size: 1.2rem;
        }

        .setup-option input {
            width: 100%;
            padding: 12px;
            margin-bottom: 10px;
            border: 2px solid #0f3460;
            border-radius: 8px;
            background: #1a1a2e;
            color: #eee;
            font-size: 1rem;
            box-sizing: border-box;
        }

        .setup-option input::placeholder {
            color: #666;
        }

        .setup-option button {
            width: 100%;
            padding: 12px;
            background: #e94560;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.2s;
        }

        .setup-option button:hover {
            background: #c73e54;
        }

        .setup-divider {
            display: flex;
            align-items: center;
            justify-content: center;
            color: #666;
            font-size: 1.5rem;
            padding-top: 60px;
        }

        /* Debug panel */
        .debug-panel {
            margin-top: 30px;
            border: 2px solid #e94560;
            border-radius: 12px;
            overflow: hidden;
            background: #0f0f23;
        }

        .debug-header {
            padding: 12px 20px;
            background: #e94560;
            color: white;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            user-select: none;
        }

        .debug-header:hover {
            background: #c73e54;
        }

        .debug-content {
            padding: 20px;
            display: none;
            max-height: 600px;
            overflow: auto;
        }

        .debug-content.visible {
            display: block;
        }

        .debug-content pre {
            margin: 0;
            font-family: 'Courier New', monospace;
            font-size: 0.85rem;
            color: #00ff88;
            white-space: pre-wrap;
            word-break: break-all;
        }

        .debug-info {
            margin-top: 15px;
            padding: 15px;
            background: #16213e;
            border-radius: 8px;
            border: 1px solid #0f3460;
        }

        .debug-info h4 {
            color: #f0c040;
            margin-bottom: 10px;
        }

        .debug-info table {
            width: 100%;
            border-collapse: collapse;
        }

        .debug-info td {
            padding: 6px 10px;
            border-bottom: 1px solid #0f3460;
        }

        .debug-info td:first-child {
            color: #aaa;
            font-weight: bold;
            width: 180px;
        }

        .debug-info td:last-child {
            color: #00ff88;
            font-family: 'Courier New', monospace;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Wordfeud</h1>

        @if (string.IsNullOrEmpty(Model.CurrentGame?.Id))
        {
            <div class="setup-panel">
                <h2>Start a Game</h2>
                
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="error">
                        @foreach (var key in ViewData.ModelState.Keys)
                        {
                            @foreach (var error in ViewData.ModelState[key]!.Errors)
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        }
                    </div>
                }

                <div class="setup-options">
                    <div class="setup-option">
                        <h3>Create New Game</h3>
                        <form method="post" asp-page-handler="CreateGame">
                            <input asp-for="PlayerName" placeholder="Enter your name" />
                            <button type="submit">Create Game</button>
                        </form>
                    </div>
                    
                    <div class="setup-divider">or</div>
                    
                    <div class="setup-option">
                        <h3>Join Existing Game</h3>
                        <form method="post" asp-page-handler="JoinGame">
                            <input asp-for="PlayerName" placeholder="Enter your name" />
                            <input asp-for="GameId" placeholder="Enter Game ID" />
                            <button type="submit">Join Game</button>
                        </form>
                    </div>
                </div>
                
                <p style="color: #aaa; margin-top: 20px;">Create a game to start playing, or join an existing game by entering the Game ID.</p>
            </div>
        }
        else
        {
            @* Status bar *@
            <div class="status-bar">
                <div>Game ID: <span class="game-id">@Model.CurrentGame.Id</span></div>
                <div>Move #: @Model.CurrentGame.MoveNumber | Bag: @Model.CurrentGame.BagCount tiles | Status: @Model.CurrentGame.Status</div>
                @if (Model.CurrentGame.ConsecutivePasses > 0)
                {
                    <div style="color: #ffc107;">Consecutive passes: @Model.CurrentGame.ConsecutivePasses</div>
                }
            </div>

            @* Refresh button *@
            <div style="text-align: center; margin-top: 10px;">
                <form method="get">
                    <button type="submit" name="refresh" value="1" class="btn-refresh">Refresh Board</button>
                </form>
            </div>

            @* Game layout *@
            <div class="game-layout">
                @* Player 1 panel *@
                <div class="player-panel @(Model.CurrentGame.Players.FirstOrDefault(p => p.Id == Model.CurrentGame.CurrentPlayerId)?.Id == (Model.CurrentGame.Players.Count > 0 ? Model.CurrentGame.Players[0].Id : null) ? "active" : "")">
                    <h3>@Model.CurrentGame.Players.FirstOrDefault()?.Name</h3>
                    <div class="score">@Model.CurrentGame.Players.FirstOrDefault()?.Score pts</div>
                    <div class="rack">
                        @foreach (var tile in Model.CurrentGame.Players.FirstOrDefault()?.Hand ?? new List<TileViewModel>())
                        {
                            var isBlankClass = tile.IsBlank ? "blank-tile" : "";
                            <div class="rack-tile @isBlankClass"
                                 draggable="true"
                                 ondragstart="handleDragStart(event, '@tile.Id', '@(tile.IsBlank ? "?" : tile.Letter)', @tile.Points, @tile.IsBlank)"
                                 title="Drag to board or click to select">
                                @(tile.IsBlank ? "?" : tile.Letter)
                                <span class="points">@tile.Points</span>
                            </div>
                        }
                    </div>
                    <div class="info">Tiles: @(Model.CurrentGame.Players.FirstOrDefault()?.Hand.Count ?? 0)</div>
                </div>

                @* Board *@
                <div class="board-container">
                    <div class="board">
                        @for (var row = 0; row < 15; row++)
                        {
                            @for (var col = 0; col < 15; col++)
                            {
                                var bonusType = IndexModel.GetBonusType(row, col);
                                var cellClass = "board-cell";
                                var displayText = "";

                                if (row == 7 && col == 7)
                                {
                                    cellClass += " center";
                                    displayText = "★";
                                }
                                else if (!string.IsNullOrEmpty(bonusType))
                                {
                                    cellClass += " " + bonusType.ToLower();
                                    displayText = bonusType;
                                }

                                // Check if a tile is on this square
                                var boardTile = Model.CurrentGame.BoardTiles.FirstOrDefault(t => t.Row == row && t.Column == col);
                                if (boardTile != null)
                                {
                                    displayText = boardTile.IsBlank ? (boardTile.BlankRepresentation ?? "?") : boardTile.Letter;
                                }

                                <div class="@cellClass"
                                     data-row="@row"
                                     data-col="@col"
                                     ondragover="event.preventDefault(); this.classList.add('drop-hover');"
                                     ondragleave="this.classList.remove('drop-hover');"
                                     ondrop="handleDrop(event, @row, @col);">
                                    @if (!string.IsNullOrEmpty(displayText))
                                    {
                                        <span>@displayText</span>
                                    }
                                    @if (boardTile != null)
                                    {
                                        <div class="tile-on-board"
                                             ondragover="event.preventDefault();"
                                             ondrop="event.preventDefault(); handleDrop(event, @row, @col);">
                                            @(boardTile.IsBlank ? (boardTile.BlankRepresentation ?? "?") : boardTile.Letter)
                                            <span class="points">@boardTile.Points</span>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>

                    @* Legend *@
                    <div class="legend">
                        <div class="legend-item"><div class="legend-box tws"></div> Triple Word</div>
                        <div class="legend-item"><div class="legend-box dws"></div> Double Word</div>
                        <div class="legend-item"><div class="legend-box tls"></div> Triple Letter</div>
                        <div class="legend-item"><div class="legend-box dls"></div> Double Letter</div>
                    </div>
                </div>

                @* Player 2 panel *@
                <div class="player-panel @(Model.CurrentGame.Players.Count > 1 && Model.CurrentGame.Players[1]?.Id == Model.CurrentGame.CurrentPlayerId ? "active" : "")">
                    <h3>@(Model.CurrentGame.Players.Count > 1 ? Model.CurrentGame.Players[1].Name : "Waiting...")</h3>
                    <div class="score">@(Model.CurrentGame.Players.Count > 1 ? Model.CurrentGame.Players[1].Score.ToString() + " pts" : "-")</div>
                    <div class="rack">
                        @if (Model.CurrentGame.Players.Count > 1)
                        {
                            foreach (var tile in Model.CurrentGame.Players[1].Hand)
                            {
                                var isBlankClass = tile.IsBlank ? "blank-tile" : "";
                                <div class="rack-tile @isBlankClass"
                                     draggable="true"
                                     ondragstart="handleDragStart(event, '@tile.Id', '@(tile.IsBlank ? "?" : tile.Letter)', @tile.Points, @tile.IsBlank)"
                                     title="Drag to board or click to select">
                                    @(tile.IsBlank ? "?" : tile.Letter)
                                    <span class="points">@tile.Points</span>
                                </div>
                            }
                        }
                    </div>
                    <div class="info">Tiles: @(Model.CurrentGame.Players.Count > 1 ? Model.CurrentGame.Players[1].Hand.Count.ToString() : "0")</div>
                </div>
            </div>

            @* Action bar *@
            <div class="action-bar">
                <h4>Actions</h4>

                @* Place tiles form *@
                <form method="post" id="placeForm" style="margin-bottom: 10px;">
                    <div class="placed-tiles" id="placedTilesPreview">
                        <span style="color: #aaa; font-size: 0.85rem;">Drag tiles from your rack onto the board</span>
                    </div>
                    <button type="submit" name="action" value="place" class="btn-place">Place Tiles</button>
                    <input type="hidden" name="SelectedTiles" id="selectedTilesInput" />
                    <input type="hidden" name="TilePositions" id="tilePositionsInput" />
                </form>

                @* Swap tiles form *@
                <form method="post">
                    <label>Swap selected tiles:
                        <input type="text" name="SelectedTiles" placeholder="Tile IDs (comma-separated)" style="width: 200px;" />
                    </label>
                    <button type="submit" name="action" value="swap" class="btn-swap">Swap Tiles</button>
                </form>

                @* Pass turn button *@
                <form method="post" style="display: inline;">
                    <button type="submit" name="action" value="pass" class="btn-pass">Pass Turn</button>
                </form>

                @* Join game form (if game not started) *@
                @if (Model.CurrentGame?.Status?.ToLower() == "waiting")
                {
                    <div style="margin-top: 15px; padding-top: 15px; border-top: 1px solid #0f3460;">
                        <h4>Join Game</h4>
                        <form method="post">
                            <input asp-for="PlayerName" placeholder="Your name" style="width: 150px;" />
                            <button type="submit" name="action" value="join" class="btn-place">Join Game</button>
                        </form>
                    </div>
                }
            </div>

            @* Error messages *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error">
                    @foreach (var key in ViewData.ModelState.Keys)
                    {
                        @foreach (var error in ViewData.ModelState[key]!.Errors)
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    }
                </div>
            }
        }
    </div>

    @* Debug Panel *@
    <div class="container">
        <div class="debug-panel">
            <div class="debug-header" onclick="toggleDebug()">
                <span>🔍 Debug Panel (Game State)</span>
                <span id="debugToggle">▼</span>
            </div>
            <div class="debug-content" id="debugContent">
                @if (Model.CurrentGame != null)
                {
                    <div class="debug-info">
                        <h4>Game Details</h4>
                        <table>
                            <tr><td>Game ID</td><td>@Model.CurrentGame.Id</td></tr>
                            <tr><td>Status</td><td>@Model.CurrentGame.Status</td></tr>
                            <tr><td>Current Player</td><td>@(Model.CurrentGame.CurrentPlayerId ?? "None")</td></tr>
                            <tr><td>Move Number</td><td>@Model.CurrentGame.MoveNumber</td></tr>
                            <tr><td>Bag Count</td><td>@Model.CurrentGame.BagCount</td></tr>
                            <tr><td>Consecutive Passes</td><td>@Model.CurrentGame.ConsecutivePasses</td></tr>
                            <tr><td>Players Count</td><td>@Model.CurrentGame.Players.Count</td></tr>
                            <tr><td>Board Tiles Count</td><td>@Model.CurrentGame.BoardTiles.Count</td></tr>
                        </table>
                    </div>

                    <div class="debug-info">
                        <h4>Players</h4>
                        <table>
                            @for (var i = 0; i < Model.CurrentGame.Players.Count; i++)
                            {
                                var p = Model.CurrentGame.Players[i];
                                <tr>
                                    <td>Player @(i + 1)</td>
                                    <td>@p.Name (ID: @p.Id, Score: @p.Score, Hand: @p.Hand.Count tiles)</td>
                                </tr>
                            }
                        </table>
                    </div>

                    <div class="debug-info">
                        <h4>Board Tiles</h4>
                        @if (Model.CurrentGame.BoardTiles.Count > 0)
                        {
                            <table>
                                @foreach (var tile in Model.CurrentGame.BoardTiles)
                                {
                                    <tr>
                                        <td>@(tile.Row),@(tile.Column)</td>
                                        <td>@(tile.IsBlank ? "?" : tile.Letter) (@tile.Points pts, Blank: @(tile.IsBlank ? "Yes" : "No"))</td>
                                    </tr>
                                }
                            </table>
                        }
                        else
                        {
                            <p style="color: #aaa;">No tiles on board yet.</p>
                        }
                    </div>

                    <div class="debug-info">
                        <h4>Raw JSON Response</h4>
                        <pre id="rawJson">@JsonSerializer.Serialize(Model.CurrentGame, new JsonSerializerOptions { WriteIndented = true, PropertyNamingPolicy = JsonNamingPolicy.CamelCase })</pre>
                    </div>
                }
                else
                {
                    <div class="debug-info">
                        <p style="color: #aaa;">No active game. Create a game to see debug information.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <script>
        // Drag-and-drop state
        var placedTiles = []; // Array of { tileId, letter, points, isBlank, row, col }

        function toggleDebug() {
            var content = document.getElementById('debugContent');
            var toggle = document.getElementById('debugToggle');
            content.classList.toggle('visible');
            toggle.textContent = content.classList.contains('visible') ? '▲' : '▼';
        }

        // Handle drag start from rack
        function handleDragStart(event, tileId, letter, points, isBlank) {
            event.dataTransfer.setData('text/plain', JSON.stringify({
                tileId: tileId,
                letter: letter,
                points: points,
                isBlank: isBlank
            }));
            event.dataTransfer.effectAllowed = 'move';
        }

        // Handle drop on board cell
        function handleDrop(event, row, col) {
            event.preventDefault();
            event.target.closest('.board-cell').classList.remove('drop-hover');

            var data = event.dataTransfer.getData('text/plain');
            if (!data) return;

            var tileInfo = JSON.parse(data);

            // Check if a tile is already placed on this cell
            var existingIndex = placedTiles.findIndex(function(t) { return t.row === row && t.col === col; });
            if (existingIndex !== -1) {
                // Replace the existing tile
                placedTiles[existingIndex] = {
                    tileId: tileInfo.tileId,
                    letter: tileInfo.letter,
                    points: tileInfo.points,
                    isBlank: tileInfo.isBlank,
                    row: row,
                    col: col
                };
            } else {
                // Add new tile
                placedTiles.push({
                    tileId: tileInfo.tileId,
                    letter: tileInfo.letter,
                    points: tileInfo.points,
                    isBlank: tileInfo.isBlank,
                    row: row,
                    col: col
                });
            }

            updatePlacedTilesPreview();
        }

        // Update the placed tiles preview area
        function updatePlacedTilesPreview() {
            var container = document.getElementById('placedTilesPreview');
            if (placedTiles.length === 0) {
                container.innerHTML = '<span style="color: #aaa; font-size: 0.85rem;">Drag tiles from your rack onto the board</span>';
                document.getElementById('selectedTilesInput').value = '';
                return;
            }

            var html = '';
            placedTiles.forEach(function(tile, index) {
                var displayLetter = tile.isBlank ? '?' : tile.letter;
                html += '<div class="placed-tile" title="' + displayLetter + ' (' + tile.points + ' pts) at ' + tile.row + ',' + tile.col + '">'
                    + displayLetter
                    + '<span class="points">' + tile.points + '</span>'
                    + '<span class="pos-info">' + tile.row + ',' + tile.col + '</span>'
                    + '<button class="remove-btn" onclick="removePlacedTile(' + index + ')">✕</button>'
                    + '</div>';
            });
            container.innerHTML = html;

            // Update hidden input with tile IDs (comma-separated)
            document.getElementById('selectedTilesInput').value = placedTiles.map(function(t) { return t.tileId; }).join(',');
            // Update TilePositions with JSON of {row, col} for each tile
            document.getElementById('tilePositionsInput').value = JSON.stringify(placedTiles.map(function(t) { return { TileId: t.tileId, Row: t.row, Column: t.col }; }));
        }

        // Remove a placed tile
        function removePlacedTile(index) {
            placedTiles.splice(index, 1);
            updatePlacedTilesPreview();
        }

        function selectTile(tileId) {
            var index = placedTiles.findIndex(function(t) { return t.tileId === tileId; });
            if (index > -1) {
                placedTiles.splice(index, 1);
                updatePlacedTilesPreview();
            } else {
                // Fallback: click to add tile at center of board (7,7) if not already placed
                var existing = placedTiles.find(function(t) { return t.tileId === tileId; });
                if (!existing) {
                    // Find a free tile from the rack with this ID
                    var rackTiles = document.querySelectorAll('.rack-tile');
                    rackTiles.forEach(function(el) {
                        if (el.getAttribute('data-tile-id') === tileId && !el.classList.contains('placed')) {
                            el.classList.add('placed');
                            el.style.opacity = '0.4';
                            // Add to placed tiles at a default position
                            placedTiles.push({
                                tileId: tileId,
                                letter: el.textContent.trim().charAt(0),
                                points: parseInt(el.getAttribute('data-points') || '0'),
                                isBlank: el.classList.contains('blank-tile'),
                                row: 7,
                                col: 7
                            });
                            updatePlacedTilesPreview();
                        }
                    });
                }
            }
        }
    </script>
</body>
</html>
