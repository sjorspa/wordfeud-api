@page
@model Wordfeud.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Wordfeud - Home";
}

<!-- Hero Section -->
<div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <!-- Logo / Title -->
    <div class="mb-8">
        <h1 class="text-6xl font-bold bg-gradient-to-r from-tile-gold via-tile-cream to-tile-gold bg-clip-text text-transparent mb-4">
            &#9993; Wordfeud
        </h1>
        <p class="text-xl text-gray-400">The ultimate word game</p>
    </div>

    <!-- Action Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 mb-12">
        <a href="/game/new" class="px-8 py-4 bg-gradient-to-r from-green-600 to-green-700 hover:from-green-500 hover:to-green-600 text-white text-lg font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-1">
            &#10133; New Game
        </a>
        <a href="/game/join" class="px-8 py-4 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-500 hover:to-blue-600 text-white text-lg font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all transform hover:-translate-y-1">
            &#9650; Join Game
        </a>
    </div>

    <!-- Active Games -->
    @if (Model.ActiveGames != null && Model.ActiveGames.Count > 0)
    {
        <div class="w-full max-w-2xl">
            <h2 class="text-2xl font-bold mb-4 text-tile-gold">Your Active Games</h2>
            <div class="bg-gray-800 rounded-xl overflow-hidden shadow-xl">
                @foreach (var game in Model.ActiveGames)
                {
                    <a href="/game/@game.Id" class="flex items-center justify-between p-4 border-b border-gray-700 hover:bg-gray-700 transition-colors block">
                        <div>
                            <span class="text-lg font-semibold">@game.Status</span>
                            <span class="text-gray-400 ml-4 text-sm">@game.PlayerCount players</span>
                        </div>
                        <span class="text-tile-gold font-mono text-sm">@game.Id</span>
                    </a>
                }
            </div>
        </div>
    }
    else
    {
        <div class="text-gray-500 text-lg">
            <p>You have no active games.</p>
            <p class="mt-2">Create a new game or join an existing one!</p>
        </div>
    }
</div>
